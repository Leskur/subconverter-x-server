{
  "name": "subconverter-x",
  "version": "0.0.1",
  "description": "轻量订阅解析与转换引擎，支持云函数与单文件部署",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "subconverter-x": "./dist/standalone.cjs"
  },
  "scripts": {
    "dev": "tsx watch src/adapters/standalone.ts serve --port 15500",
    "build": "tsc --noEmit && node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "subscription",
    "clash",
    "sing-box",
    "vless",
    "trojan"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.5",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  },
  "dependencies": {
    "yaml": "^2.8.0"
  }
}
